# Database (MySQL - legacy, optional)
DATABASE_URL=mysql://user:password@localhost:3306/priyank_portfolio

# Supabase Configuration (for testimonials database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Vite-accessible Supabase keys (for frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Legacy MySQL (optional - only if not using Supabase)
DATABASE_URL=mysql://user:password@host:port/database

# JWT Secret for authentication
JWT_SECRET=your-super-secret-jwt-key

# Environment
NODE_ENV=development

# Admin Panel Password
ADMIN_PASSWORD=your-secure-admin-password

# App Configuration
VITE_APP_TITLE=Priyank Garg
VITE_APP_LOGO=/logo.svg
VITE_APP_TITLE=Priyank Garg | Senior Product Manager Portfolio
VITE_APP_LOGO=/logo.svg
